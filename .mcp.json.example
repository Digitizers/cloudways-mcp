{
  "_comment": "Per-account connection skeleton. Replace url and auth with the OFFICIAL Cloudways (Remote) MCP details from the support article (https://support.cloudways.com/en/articles/14654372) — the endpoint and auth method are not assumed here. One connection per account; name each cloudways-<client>. Copy to .mcp.json (gitignored) and fill real credentials; never commit them.",
  "mcpServers": {
    "cloudways-clientA": {
      "type": "http",
      "url": "https://REPLACE-WITH-OFFICIAL-CLOUDWAYS-MCP-ENDPOINT/mcp",
      "_auth": "Set per the official article (e.g. API key / OAuth), using clientA's Cloudways email + API key from Account -> API."
    },
    "cloudways-clientB": {
      "type": "http",
      "url": "https://REPLACE-WITH-OFFICIAL-CLOUDWAYS-MCP-ENDPOINT/mcp",
      "_auth": "Set per the official article, using clientB's Cloudways email + API key from Account -> API."
    }
  }
}
