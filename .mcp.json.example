{
  "_comment": "Copy to .mcp.json (gitignored) and fill in real credentials; never commit them. One connection per Cloudways account, named cloudways-<client>. Endpoint and headers follow the official support article (https://support.cloudways.com/en/articles/14654372): the hosted MCP is at https://mcp.cloudways.com/mcp/, authenticated via the case-sensitive headers X-Access-Token and X-Mcp-Host. Generate an Access Token at platform.cloudways.com (API section) with the minimum role the connection needs: READ for monitoring-only, LIMITED for specific workflows, FULL ACCESS only when changes are required. Legacy X-CW-Email/X-CW-Api-Key headers are deprecated; the old API key stops working on October 15, 2026.",
  "mcpServers": {
    "cloudways-clientA": {
      "type": "http",
      "url": "https://mcp.cloudways.com/mcp/",
      "headers": {
        "X-Access-Token": "CLIENT_A_ACCESS_TOKEN",
        "X-Mcp-Host": "claude-code"
      }
    },
    "cloudways-clientB": {
      "type": "http",
      "url": "https://mcp.cloudways.com/mcp/",
      "headers": {
        "X-Access-Token": "CLIENT_B_ACCESS_TOKEN",
        "X-Mcp-Host": "claude-code"
      }
    }
  }
}
