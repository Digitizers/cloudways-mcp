{
  "_comment": "Copy to .mcp.json (gitignored) and fill in real credentials; never commit them. One connection per Cloudways account, named cloudways-<client>. Endpoint and headers follow the official support article (https://support.cloudways.com/en/articles/14654372): the hosted MCP is at https://mcp.cloudways.com/mcp/, authenticated via case-sensitive headers X-CW-Email, X-CW-Api-Key, and X-Mcp-Host. Get the API key at platform.cloudways.com -> API Integration.",
  "mcpServers": {
    "cloudways-clientA": {
      "type": "http",
      "url": "https://mcp.cloudways.com/mcp/",
      "headers": {
        "X-CW-Email": "clientA@example.com",
        "X-CW-Api-Key": "CLIENT_A_API_KEY",
        "X-Mcp-Host": "claude-code"
      }
    },
    "cloudways-clientB": {
      "type": "http",
      "url": "https://mcp.cloudways.com/mcp/",
      "headers": {
        "X-CW-Email": "clientB@example.com",
        "X-CW-Api-Key": "CLIENT_B_API_KEY",
        "X-Mcp-Host": "claude-code"
      }
    }
  }
}
