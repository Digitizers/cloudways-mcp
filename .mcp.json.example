{
  "_comment": "Example for the SELF-HOSTED community cw-mcp server (Option 2, localhost:7000). For the OFFICIAL Cloudways Remote MCP (Option 1, recommended) follow the connection steps in the official support article — endpoint/auth may differ; do not assume this URL. One connection per Cloudways account. Copy to .mcp.json (gitignored) and fill real credentials. Header names are case-insensitive.",
  "mcpServers": {
    "cloudways-clientA": {
      "type": "http",
      "url": "http://127.0.0.1:7000/mcp",
      "headers": {
        "x-cloudways-email": "clientA@example.com",
        "x-cloudways-api-key": "CLIENT_A_API_KEY"
      }
    },
    "cloudways-clientB": {
      "type": "http",
      "url": "http://127.0.0.1:7000/mcp",
      "headers": {
        "x-cloudways-email": "clientB@example.com",
        "x-cloudways-api-key": "CLIENT_B_API_KEY"
      }
    }
  }
}
